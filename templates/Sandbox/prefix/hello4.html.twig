<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Bienvenue !</title>
    </head>
<body>
    <h1>Bienvenue {{ prenom }}</h1>
    Mes jeux préférés sont&nbsp;:
    {% set i = 1 %}
    <table>
    <tr><th>ID jeu</th><th>NOM jeu</th></tr>
    {% for jeu in jeux %}
        <tr><td>{{ i }}</td><td>{{ jeu }}</td></tr>
        {% set i = i+1 %}
    {% else %}
        je ne préfère aucun jeu&nbsp;!
    {% endfor %}
    </table>
</body>

</html>
